# Open man page as PDF
function manpdf() {
 man -t "${1}" | open -f -a /Applications/Preview.app/
}

# Open query in Dash app
dash() {
  case $# in
    1) QUERY="$1";;
    2) QUERY="$1%3A$2";; # %3A is : char
    *) echo "Usage: dash [docset] query"; return 1;
  esac
  open "dash://$QUERY"
}

# Weather
meteo() {
  local LOCALE
  LOCALE=$(echo "${LANG:-en}" | cut -c1-2)
  if [ $# -eq 0 ]; then
    local LOCATION
    LOCATION=$(curl -s ipinfo.io/loc)
  else
    local LOCATION=$1
  fi
  curl -s "$LOCALE.wttr.in/$LOCATION"
}

# UPDATE 2022-01-04: Running yq as docker container makes it tedious to update yaml in place using environment variables
# therefore, just install it using brew
# yq() {
#   docker run --rm -i -v "${PWD}":/workdir mikefarah/yq "$@"
# }

dive() {
  docker run --rm -it -v /var/run/docker.sock:/var/run/docker.sock wagoodman/dive:latest "$@"
}

kcat() {
  docker run -it --rm --network=host edenhill/kcat:1.7.0 "$@"
}

# Create a file and directories in the path along the way
touch2() { mkdir -p "$(dirname "$1")" && touch "$1" ; }

# =============================================================================
# iTerm2 Broadcasting Functions
# =============================================================================

# Broadcast AWS credentials to OTHER tabs only (FIXED)
broadcast_aws_to_other_tabs() {
    # Get current AWS env vars
    aws_vars=$(env | grep '^AWS_' | sed 's/^/export /')

    if [ -z "$aws_vars" ]; then
        echo "No AWS environment variables found"
        return 1
    fi

    # Send to other tabs only using session comparison
    osascript -e "
    tell application \"iTerm2\"
        tell current window
            set currentSession to current session
            repeat with t in tabs
                tell current session of t
                    if it is not equal to currentSession then
                        write text \"$aws_vars\"
                    end if
                end tell
            end repeat
        end tell
    end tell"

    echo "AWS credentials broadcasted to other iTerm2 tabs (excluding current)"
}

# Broadcast current directory to OTHER iTerm2 tabs only (FIXED)
broadcast_cd_to_other_tabs() {
    current_dir=$(pwd)

    osascript -e "
    tell application \"iTerm2\"
        tell current window
            set currentSession to current session
            repeat with t in tabs
                tell current session of t
                    if it is not equal to currentSession then
                        write text \"cd '$current_dir'\"
                    end if
                end tell
            end repeat
        end tell
    end tell"

    echo "Broadcasted 'cd $current_dir' to other iTerm2 tabs (excluding current)"
}

# General command broadcaster - send to OTHER tabs only (FIXED)
broadcast_to_other_tabs() {
    local command="$*"

    if [ -z "$command" ]; then
        echo "Usage: broadcast_to_other_tabs <command>"
        return 1
    fi

    osascript -e "
    tell application \"iTerm2\"
        tell current window
            set currentSession to current session
            repeat with t in tabs
                tell current session of t
                    if it is not equal to currentSession then
                        write text \"$command\"
                    end if
                end tell
            end repeat
        end tell
    end tell"

    echo "Broadcasted '$command' to other iTerm2 tabs (excluding current)"
}

# General command broadcaster - send to ALL tabs
broadcast_to_iterm_tabs() {
    local command="$*"

    if [ -z "$command" ]; then
        echo "Usage: broadcast_to_iterm_tabs <command>"
        return 1
    fi

    osascript -e "
    tell application \"iTerm2\"
        tell current window
            repeat with t in tabs
                tell current session of t
                    write text \"$command\"
                end tell
            end repeat
        end tell
    end tell"

    echo "Broadcasted '$command' to all iTerm2 tabs"
}
